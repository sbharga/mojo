{
  "name": "mojo-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "prepare:stockfish": "node scripts/prepare-stockfish.mjs",
    "predev": "npm run prepare:stockfish",
    "prebuild": "npm run prepare:stockfish",
    "build:engine": "node ../engine/build-wasm.mjs",
    "bench:engine": "npm run build:engine && node ../engine/bench.mjs",
    "selfplay": "node ../engine/selfplay.mjs",
    "tune:eval": "cargo run --manifest-path ../engine/Cargo.toml --features tuning --bin texel --",
    "test:openings": "node ../engine/validate-openings.mjs",
    "test:selfplay": "node ../engine/selfplay.mjs --baseline engine/pkg/mojo_engine_bg.wasm --depth 2 --openings 1 --max-plies 20",
    "test:strength": "node ../engine/accuracy.mjs && node ../engine/accuracy.mjs --wasm ../engine/pkg/mojo_engine_simd_bg.wasm",
    "test:cancellation": "node ../engine/validate-cancellation.mjs",
    "test:seeding": "node ../engine/validate-seeding.mjs",
    "test:size": "node ../engine/validate-size.mjs",
    "dev": "npm run build:engine && vite",
    "build": "npm run build:engine && tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "check": "npm run lint && tsc -b && npm run test && npm run test:openings && npm run test:strength && npm run test:cancellation && npm run test:seeding && npm run test:size && npm run test:selfplay"
  },
  "dependencies": {
    "chess.js": "^1.4.0",
    "react": "^19.1.0",
    "react-chessboard": "^4.7.1",
    "react-dom": "^19.1.0",
    "stockfish": "18.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.24.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^29.1.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.29.0",
    "vite": "^6.3.3",
    "vitest": "^3.1.2"
  }
}
