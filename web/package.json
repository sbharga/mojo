{
  "name": "mojo-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "prepare:stockfish": "node scripts/prepare-stockfish.mjs",
    "prepare:engine-versions": "node scripts/prepare-engine-versions.mjs",
    "prepare:assets": "npm run prepare:stockfish && npm run prepare:engine-versions",
    "predev": "npm run prepare:assets",
    "prebuild": "npm run prepare:assets",
    "build:engine": "node ../engine/build-wasm.mjs",
    "build:engine:book": "node ../engine/build-wasm.mjs --features book",
    "build:engine:spsa": "cd ../engine && wasm-pack build --target web --out-dir pkg-spsa --release -- --features spsa",
    "bench:engine": "npm run build:engine && node ../engine/bench.mjs",
    "selfplay": "node ../engine/selfplay.mjs",
    "tune:eval": "cargo run --manifest-path ../engine/Cargo.toml --features tuning --bin texel --",
    "tune:search": "node ../engine/spsa.mjs",
    "test:openings": "node ../engine/validate-openings.mjs",
    "test:book": "node ../engine/validate-book.mjs",
    "test:selfplay": "node ../engine/selfplay.mjs --baseline engine/pkg/mojo_engine_bg.wasm --depth 2 --openings 1 --max-plies 20",
    "test:strength": "node ../engine/accuracy.mjs && node ../engine/accuracy.mjs --wasm ../engine/pkg/mojo_engine_simd_bg.wasm",
    "test:cancellation": "node ../engine/validate-cancellation.mjs",
    "test:seeding": "node ../engine/validate-seeding.mjs",
    "test:size": "node ../engine/validate-size.mjs",
    "dev": "npm run build:engine && vite",
    "dev:book": "npm run prepare:stockfish && npm run build:engine:book && vite",
    "build": "npm run build:engine && tsc -b && vite build",
    "build:book": "npm run build:engine:book && tsc -b && vite build",
    "lint": "oxlint .",
    "test": "vitest run",
    "check": "npm run lint && tsc -b && npm run test && npm run test:openings && npm run test:strength && npm run test:cancellation && npm run test:seeding && npm run test:size && npm run test:selfplay"
  },
  "dependencies": {
    "chess.js": "^1.4.0",
    "react": "^19.2.7",
    "react-chessboard": "^5.10.0",
    "react-dom": "^19.2.7",
    "stockfish": "18.0.8"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "oxlint": "^1.74.0",
    "typescript": "~7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
