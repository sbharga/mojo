{
  "name": "mojo-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build:engine": "cd ../engine && wasm-pack build --target web --out-dir pkg --release",
    "bench:engine": "npm run build:engine && node ../engine/bench.mjs",
    "dev": "npm run build:engine && vite",
    "build": "npm run build:engine && tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "check": "npm run lint && tsc -b && npm run test"
  },
  "dependencies": {
    "chess.js": "^1.4.0",
    "react": "^19.1.0",
    "react-chessboard": "^4.7.1",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.24.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.29.0",
    "vite": "^6.3.3",
    "vitest": "^3.1.2"
  }
}
